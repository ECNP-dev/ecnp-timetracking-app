
{
  "name": "ecnp-time-tracker",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",

  "scripts": {
    "react-start": "vite",
    "react-build": "vite build",
    "electron": "electron .",
    "dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && npm run electron\"",
    "dist": "npm run react-build && electron-builder"
  },

  "build": {
    "appId": "org.ecnp.timetracker",

    "directories": {
      "buildResources": "electron/assets"
    },

    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],

    "extraResources": [
      {
        "from": "electron/assets",
        "to": "assets"
      }
    ],

    "win": {
      "icon": "electron/assets/app-icon.ico",
      "target": [
        { "target": "dir", "arch": "x64" },
        { "target": "zip", "arch": "x64" }
      ]
    },

    "linux": {
      "icon": "electron/assets/app-icon-256.png",
      "category": "Utility"
    }
  },

  "dependencies": {
    "xlsx": "^0.18.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },

  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2"
  }
}
